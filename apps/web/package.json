{
  "name": "@api-spend/web",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seed.ts"
  },
  "dependencies": {
    "@api-spend/runtime-ingest": "workspace:*",
    "@api-spend/scanner": "workspace:*",
    "@api-spend/shared": "workspace:*",
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-cost-explorer": "^3.1018.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "inngest": "^4.1.0",
    "lucide-react": "^1.7.0",
    "next": "16.2.1",
    "next-auth": "5.0.0-beta.30",
    "pg": "^8.20.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "recharts": "^3.8.1",
    "resend": "^6.9.4",
    "tsx": "^4.21.0",
    "unzipper": "^0.12.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/unzipper": "^0.10.11",
    "prisma": "^7.5.0",
    "typescript": "^5.7.3"
  }
